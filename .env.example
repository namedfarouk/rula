# OnchainOS API key (used for real balance + transaction history lookups)
VITE_ONCHAINOS_API_KEY=

# The Agentic Wallet address Rula monitors and enforces rules against.
# All on-chain activity is driven by this wallet via the OnchainOS API.
VITE_AGENTIC_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
